<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[%d{HH:mm:ss}] [%level] [%logger{1}] %msg%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <!-- Shorten Hikari -->
        <Logger name="com.zaxxer.hikari" level="info" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- Shorten JDA -->
        <Logger name="net.dv8tion.jda" level="info" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- Your plugin -->
        <Logger name="Link" level="info" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>